# claude-inbox environment variables
# Copy to .env and fill in values:
#   cp .env.example .env
#   echo "DOCKER_UID=$(id -u)" >> .env
#   echo "DOCKER_GID=$(id -g)" >> .env

# --- Required: user mapping ---
# Must match the owner of ~/.claude and ~/.claude.json on the host.
# Run: id -u && id -g
DOCKER_UID=1000
DOCKER_GID=1000

# --- Claude Code authentication ---
# Max plan: run `claude login` on the host first.
#   ~/.claude/ and ~/.claude.json are bind-mounted into the container.
#   ANTHROPIC_API_KEY is not needed.
# API plan: uncomment and set ANTHROPIC_API_KEY instead.
# ANTHROPIC_API_KEY=

# --- Required ---

# Telegram Bot token (from BotFather)
TELEGRAM_BOT_TOKEN=

# Allowed Telegram chat IDs (comma-separated). Required: bridge won't start without this.
# Find your chat_id: message @userinfobot on Telegram.
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Optional ---

# System monitoring (separate bot/chat for ops alerts)
# OBSERVE_TELEGRAM_BOT_TOKEN=
# OBSERVE_TELEGRAM_CHAT_ID=

# GitHub token (higher rate limit for web-collect skill)
# GITHUB_TOKEN=

# Inbox directory (default: ~/.claude-inbox)
# CLAUDE_INBOX=~/.claude-inbox

# Worker scaling (default: 1)
# WORKERS=1

# Claude model (default: claude's default). Aliases: opus, sonnet, haiku
# CLAUDE_MODEL=sonnet

# NotebookLM (nlm CLI) config dir (default: ~/.config/nlm on host)
# Run `bin/claude-inbox-setup nlm-login` to authenticate.
# Auth is cookie-based and expires every 2-4 weeks.
# NLM_CONFIG_DIR=~/.config/nlm

# claude-mem: cross-session/cross-channel memory (separate container)
# Run `bin/claude-inbox-setup claude-mem` to configure MCP server in ~/.claude/settings.json
# Data stored in ~/.claude-mem/ on host (bind-mounted into claude-mem container)
# CLAUDE_MEM_DATA_DIR=~/.claude-mem

# SwitchBot API (from SwitchBot app > Profile > Preferences > Developer Options)
# SWITCHBOT_TOKEN=
# SWITCHBOT_SECRET=

# Chrome profile for browser-use skill (optional)
# Mount your Chrome profile so browser-use can access existing logins/cookies.
# Run `google-chrome --user-data-dir=~/.config/google-chrome` on the host first to log in.
# CHROME_PROFILE_DIR=~/.config/google-chrome
