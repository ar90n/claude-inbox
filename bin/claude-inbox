#!/bin/bash
# claude-inbox: Entry point for claude-inbox
#
# Intended to be launched by systemd / launchd / supervisord.
# Manages worker processes and auto-restarts them on failure.
#
# Usage:
#   bin/claude-inbox                    # 1 worker
#   WORKERS=3 bin/claude-inbox         # 3 workers
#   systemctl start claude-inbox       # via systemd
#
# Environment variables:
#   CLAUDE_INBOX                inbox directory (default: ~/.claude-inbox)
#   WORKERS                     number of workers (default: 1)
#   CLAUDE_INBOX_WORKDIR        working directory for claude -p
#   OBSERVE_TELEGRAM_BOT_TOKEN  monitoring bot token
#   OBSERVE_TELEGRAM_CHAT_ID    monitoring chat ID

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
INBOX="${CLAUDE_INBOX:-$HOME/.claude-inbox}"
NUM_WORKERS="${WORKERS:-1}"

# --- Initialization ---
mkdir -p "$INBOX"/{tmp,new,cur,done,failed,log}

source "$ROOT_DIR/lib/observe.sh"

log() { printf '[%s] [inbox] %s\n' "$(date -Is)" "$*" >&2; }

# --- Worker management ---
declare -A WORKER_PIDS

start_worker() {
    local id=$1
    "$SCRIPT_DIR/claude-inbox-worker" &
    local pid=$!
    WORKER_PIDS[$id]=$pid
    log "worker $id started (pid=$pid)"
}

stop_all() {
    log "shutting down..."
    observe "claude-inbox shutting down ($(date -Is))"
    for id in "${!WORKER_PIDS[@]}"; do
        local pid=${WORKER_PIDS[$id]}
        kill "$pid" 2>/dev/null || true
    done
    wait 2>/dev/null || true
    log "all workers stopped"
    exit 0
}

trap stop_all INT TERM

# --- Startup ---
log "starting claude-inbox (workers=$NUM_WORKERS, inbox=$INBOX)"
observe "claude-inbox started (workers=$NUM_WORKERS)"

for i in $(seq 1 "$NUM_WORKERS"); do
    start_worker "$i"
done

# --- Supervision loop: restart dead workers ---
while true; do
    for id in "${!WORKER_PIDS[@]}"; do
        pid=${WORKER_PIDS[$id]}
        if ! kill -0 "$pid" 2>/dev/null; then
            log "worker $id (pid=$pid) died, restarting..."
            observe "worker $id died, restarting"
            start_worker "$id"
        fi
    done
    sleep 5
done
