#!/bin/bash
# inbox-add: CLI tool to submit tasks to the inbox queue
#
# Usage:
#   inbox-add "Collect today's top 10 from HN and GitHub Trending, send via Telegram"
#   echo "prompt body" | inbox-add
#   inbox-add --priority 1 "Urgent task"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
export CLAUDE_INBOX="${CLAUDE_INBOX:-$HOME/.claude-inbox}"

source "$ROOT_DIR/lib/task.sh"

PRIORITY=5
PROMPT=""

while [ $# -gt 0 ]; do
    case "$1" in
        --priority) PRIORITY="$2"; shift 2 ;;
        --help|-h)
            echo "Usage: inbox-add [--priority N] [PROMPT]"
            echo "  If PROMPT is omitted, reads from stdin"
            exit 0
            ;;
        *) PROMPT="$1"; shift ;;
    esac
done

[ -z "$PROMPT" ] && PROMPT=$(cat)
[ -z "$PROMPT" ] && { echo "ERROR: no prompt" >&2; exit 1; }

path=$(task_submit --prompt "$PROMPT" --priority "$PRIORITY")
echo "submitted: $path"
