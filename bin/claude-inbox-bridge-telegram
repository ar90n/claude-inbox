#!/bin/bash
# claude-inbox-bridge-telegram: Telegram -> inbox bridge (stateless)
#
# Long-polls Telegram Bot API, converts messages to task files.
# session_id is computed deterministically from chat_id alone:
#   uuid5("telegram:{chat_id}")
#
# Runs as a daemon (always loops). Use systemd to manage lifecycle.
#
# Usage:
#   bin/claude-inbox-bridge-telegram
#   bin/claude-inbox-bridge-telegram --skip-pending   # ignore queued messages on startup
#   systemctl --user start bridge-telegram

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
export CLAUDE_INBOX="${CLAUDE_INBOX:-$HOME/.claude-inbox}"

source "$ROOT_DIR/lib/task.sh"
source "$ROOT_DIR/lib/notify.sh"
source "$ROOT_DIR/lib/observe.sh"
source "$ROOT_DIR/lib/util.sh"

OFFSET_FILE="$CLAUDE_INBOX/.bridge-telegram-offset"

# Atomic offset update: write-to-tmp + mv to prevent corruption on SIGKILL
update_offset() {
    local val="$1"
    local tmp
    tmp=$(mktemp "$CLAUDE_INBOX/tmp/.offset.XXXXXX")
    echo "$val" > "$tmp"
    mv "$tmp" "$OFFSET_FILE"
}

SKIP_PENDING=false
for arg in "$@"; do
    [ "$arg" = "--skip-pending" ] && SKIP_PENDING=true
done

token="${TELEGRAM_BOT_TOKEN:-}"
[ -z "$token" ] && { echo "error: TELEGRAM_BOT_TOKEN not set" >&2; exit 1; }

# Required allowlist: comma-separated chat IDs (e.g. "12345,67890")
ALLOWED_CHAT_IDS="${TELEGRAM_ALLOWED_CHAT_IDS:-}"
[ -z "$ALLOWED_CHAT_IDS" ] && { echo "error: TELEGRAM_ALLOWED_CHAT_IDS not set" >&2; exit 1; }

is_allowed() {
    local chat_id="$1"
    local id
    for id in ${ALLOWED_CHAT_IDS//,/ }; do
        [ "$id" = "$chat_id" ] && return 0
    done
    return 1
}

offset=0
[ -f "$OFFSET_FILE" ] && offset=$(cat "$OFFSET_FILE")

# --skip-pending: advance offset to latest update so queued messages are ignored
if [ "$SKIP_PENDING" = true ]; then
    latest=$(curl -sf "https://api.telegram.org/bot${token}/getUpdates?offset=-1" 2>/dev/null \
        | jq -r '.result[-1].update_id // empty')
    if [ -n "$latest" ]; then
        offset=$((latest + 1))
        update_offset "$offset"
        echo "[bridge-telegram] skip-pending: offset set to $offset" >&2
    fi
fi

observe "bridge-telegram started"

while true; do
    [ -f "$OFFSET_FILE" ] && offset=$(cat "$OFFSET_FILE")
    response=$(curl -sf "https://api.telegram.org/bot${token}/getUpdates?offset=${offset}&timeout=30" 2>/dev/null) || {
        sleep 5; continue
    }

    echo "$response" | jq -c '.result[]' 2>/dev/null | while read -r update; do
        text=$(echo "$update" | jq -r '.message.text // empty')
        chat_id=$(echo "$update" | jq -r '.message.chat.id // empty')
        update_id=$(echo "$update" | jq -r '.update_id')
        msg_id=$(echo "$update" | jq -r '.message.message_id // empty')
        user_name=$(echo "$update" | jq -r '.message.from.first_name // "User"')

        offset=$((update_id + 1))
        update_offset "$offset"

        [ -z "$chat_id" ] && continue

        if ! is_allowed "$chat_id"; then
            echo "[bridge-telegram] rejected: chat_id=$chat_id not in allowlist" >&2
            continue
        fi

        # Detect file attachments (photo, document, audio, voice, video)
        caption=$(echo "$update" | jq -r '.message.caption // empty')
        file_id="" file_name=""
        for ftype in photo document audio voice video_note video; do
            if [ "$ftype" = "photo" ]; then
                file_id=$(echo "$update" | jq -r '.message.photo[-1].file_id // empty')
                [ -n "$file_id" ] && file_name="photo_${chat_id}_${msg_id}.jpg"
            else
                file_id=$(echo "$update" | jq -r ".message.${ftype}.file_id // empty")
                if [ -n "$file_id" ]; then
                    file_name=$(echo "$update" | jq -r ".message.${ftype}.file_name // empty")
                    [ -z "$file_name" ] && file_name="${ftype}_${chat_id}_${msg_id}"
                fi
            fi
            [ -n "$file_id" ] && break
        done

        # Skip if neither text nor file
        [ -z "$text" ] && [ -z "$file_id" ] && continue

        session_id=$(generate_session_id "telegram:${chat_id}")

        # Use caption as text for file messages
        [ -z "$text" ] && text="$caption"

        # Model prefix: /haiku, /sonnet, /opus at start of message
        model=""
        case "$text" in
            /haiku\ *|/haiku)  model="haiku";  text="${text#/haiku}" ; text="${text# }" ;;
            /sonnet\ *|/sonnet) model="sonnet"; text="${text#/sonnet}"; text="${text# }" ;;
            /opus\ *|/opus)    model="opus";   text="${text#/opus}"  ; text="${text# }" ;;
        esac

        # Download file if present
        files_meta=""
        if [ -n "$file_id" ]; then
            tg_resp=$(curl -sf "https://api.telegram.org/bot${token}/getFile?file_id=${file_id}") || true
            tg_path=$(echo "$tg_resp" | jq -r '.result.file_path // empty')
            if [ -n "$tg_path" ]; then
                mkdir -p "$CLAUDE_INBOX/tmp"
                local_path="$CLAUDE_INBOX/tmp/$file_name"
                if curl -sf "https://api.telegram.org/file/bot${token}/${tg_path}" -o "$local_path"; then
                    files_meta=" files=$local_path"
                else
                    echo "[bridge-telegram] file download failed: $file_name" >&2
                fi
            fi
        fi

        # Sanitize user_name: strip brackets, pipes, newlines, and spaces to prevent metadata injection
        # Spaces would split into separate k=v pairs in the metadata header
        safe_name=$(printf '%s' "$user_name" | tr -d '[]|\n\r ' | tr -d '=' | cut -c1-64)

        prompt="[from=$safe_name channel=telegram chat_id=$chat_id msg_id=$msg_id session_id=$session_id${model:+ model=$model}${files_meta}]

$text"

        task_submit --prompt "$prompt"
        echo "[bridge-telegram] queued: ${text:-$file_name} (session=$session_id${model:+, model=$model})" >&2
    done
done
