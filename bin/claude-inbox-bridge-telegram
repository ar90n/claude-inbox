#!/bin/bash
# claude-inbox-bridge-telegram: Telegram -> inbox bridge (stateless)
#
# Long-polls Telegram Bot API, converts messages to task files.
# session_id is computed deterministically from chat_id alone:
#   uuid5("telegram:{chat_id}")
#
# Runs as a daemon (always loops). Use systemd to manage lifecycle.
#
# Usage:
#   bin/claude-inbox-bridge-telegram
#   bin/claude-inbox-bridge-telegram --skip-pending   # ignore queued messages on startup
#   systemctl --user start bridge-telegram

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
export CLAUDE_INBOX="${CLAUDE_INBOX:-$HOME/.claude-inbox}"

source "$ROOT_DIR/lib/task.sh"
source "$ROOT_DIR/lib/observe.sh"

OFFSET_FILE="$CLAUDE_INBOX/.bridge-telegram-offset"

# uuid5 (deterministic: same input -> always the same UUID)
generate_session_id() {
    python3 -c "import uuid; print(uuid.uuid5(uuid.NAMESPACE_URL, '$1'))"
}

SKIP_PENDING=false
for arg in "$@"; do
    [ "$arg" = "--skip-pending" ] && SKIP_PENDING=true
done

token="${TELEGRAM_BOT_TOKEN:-}"
[ -z "$token" ] && { echo "error: TELEGRAM_BOT_TOKEN not set" >&2; exit 1; }

# Required allowlist: comma-separated chat IDs (e.g. "12345,67890")
ALLOWED_CHAT_IDS="${TELEGRAM_ALLOWED_CHAT_IDS:-}"
[ -z "$ALLOWED_CHAT_IDS" ] && { echo "error: TELEGRAM_ALLOWED_CHAT_IDS not set" >&2; exit 1; }

is_allowed() {
    local chat_id="$1"
    local id
    for id in ${ALLOWED_CHAT_IDS//,/ }; do
        [ "$id" = "$chat_id" ] && return 0
    done
    return 1
}

offset=0
[ -f "$OFFSET_FILE" ] && offset=$(cat "$OFFSET_FILE")

# --skip-pending: advance offset to latest update so queued messages are ignored
if [ "$SKIP_PENDING" = true ]; then
    latest=$(curl -sf "https://api.telegram.org/bot${token}/getUpdates?offset=-1" 2>/dev/null \
        | jq -r '.result[-1].update_id // empty')
    if [ -n "$latest" ]; then
        offset=$((latest + 1))
        echo "$offset" > "$OFFSET_FILE"
        echo "[bridge-telegram] skip-pending: offset set to $offset" >&2
    fi
fi

observe "bridge-telegram started"

while true; do
    [ -f "$OFFSET_FILE" ] && offset=$(cat "$OFFSET_FILE")
    response=$(curl -sf "https://api.telegram.org/bot${token}/getUpdates?offset=${offset}&timeout=30" 2>/dev/null) || {
        sleep 5; continue
    }

    echo "$response" | jq -c '.result[]' 2>/dev/null | while read -r update; do
        text=$(echo "$update" | jq -r '.message.text // empty')
        chat_id=$(echo "$update" | jq -r '.message.chat.id // empty')
        update_id=$(echo "$update" | jq -r '.update_id')
        msg_id=$(echo "$update" | jq -r '.message.message_id // empty')
        user_name=$(echo "$update" | jq -r '.message.from.first_name // "User"')

        offset=$((update_id + 1))
        echo "$offset" > "$OFFSET_FILE"

        [ -z "$text" ] && continue
        [ -z "$chat_id" ] && continue

        if ! is_allowed "$chat_id"; then
            echo "[bridge-telegram] rejected: chat_id=$chat_id not in allowlist" >&2
            continue
        fi

        session_id=$(generate_session_id "telegram:${chat_id}")

        prompt="[from=$user_name channel=telegram chat_id=$chat_id msg_id=$msg_id session_id=$session_id]

$text"

        task_submit --prompt "$prompt"
        echo "[bridge-telegram] queued: $text (session=$session_id)" >&2
    done
done
