#!/bin/bash
# claude-inbox-cron: Cron scheduler daemon
#
# Reads job definitions from $CLAUDE_INBOX/schedule/cron.d/*.job
# Checks schedules every 30 seconds and submits matching tasks via task_submit.
#
# Session IDs are deterministic per job name: uuid5("cron:{name}")
# Last-run state stored in $CLAUDE_INBOX/schedule/state/cron/{name}.last
#
# Usage:
#   bin/claude-inbox-cron

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
export CLAUDE_INBOX="${CLAUDE_INBOX:-$HOME/.claude-inbox}"

source "$ROOT_DIR/lib/task.sh"
source "$ROOT_DIR/lib/cron.sh"
source "$ROOT_DIR/lib/observe.sh"

CRON_DIR="$SCHEDULE_DIR/cron.d"
mkdir -p "$CRON_DIR" "$CRON_STATE_DIR" "$SCHEDULE_DIR/tmp"

log() { printf '[%s] [cron] %s\n' "$(date -Is)" "$*" >&2; }

generate_session_id() {
    python3 -c "import uuid; print(uuid.uuid5(uuid.NAMESPACE_URL, '$1'))"
}

# --- Main loop ---
log "started (cron_dir=$CRON_DIR)"
observe "cron scheduler started"

while true; do
    for job_file in "$CRON_DIR"/*.job; do
        [ -f "$job_file" ] || continue

        parse_job "$job_file"

        # Validate required fields
        if [ -z "$job_name" ] || [ -z "$job_schedule" ] || [ -z "$job_prompt" ]; then
            log "SKIP $(basename "$job_file"): missing name/schedule/prompt"
            continue
        fi

        # Check if schedule matches current time
        cron_matches "$job_schedule" || continue

        # Check if already ran this minute
        already_ran "$job_name" && continue

        # Build task metadata header
        session_id=$(generate_session_id "cron:${job_name}")
        header="[from=cron channel=${job_channel:-cron} job=${job_name} session_id=${session_id}"
        [ -n "$job_chat_id" ] && header="$header chat_id=$job_chat_id"
        [ -n "$job_model" ] && header="$header model=$job_model"
        header="$header]"

        prompt="${header}

${job_prompt}"

        task_submit --prompt "$prompt" --priority "$job_priority"
        mark_ran "$job_name"
        log "SUBMITTED job=$job_name schedule='$job_schedule'"
    done

    sleep 30
done
