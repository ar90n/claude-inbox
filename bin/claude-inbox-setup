#!/bin/bash
# claude-inbox-setup: one-time setup tasks for the worker container
#
# Usage:
#   docker exec -it <worker> bin/claude-inbox-setup <command>
#
# Commands:
#   nlm-login    Authenticate NotebookLM (requires DISPLAY + X11)
#   claude-mem   Configure claude-mem MCP server in ~/.claude/settings.json
#   status       Show setup status

set -euo pipefail

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") <command>

Commands:
  login        Authenticate Claude Code (run once after first start)
               docker compose exec worker bin/claude-inbox-setup login

  nlm-login    Authenticate NotebookLM via kasmweb Chrome
               docker compose exec worker bin/claude-inbox-setup nlm-login
               Then open https://localhost:6901 and complete Google login

  claude-mem   Add claude-mem MCP server to ~/.claude/settings.json
               docker compose exec worker bin/claude-inbox-setup claude-mem

  gws-login    Authenticate Google Workspace CLI (Gmail, Calendar, Drive, etc.)
               Requires GOOGLE_WORKSPACE_CLI_CLIENT_ID and _CLIENT_SECRET in .env
               docker compose exec -it worker bin/claude-inbox-setup gws-login

  playwright   Add Playwright MCP server (remote Chrome via CDP)
               docker compose exec worker bin/claude-inbox-setup playwright

  install-skills  Install agent CLAUDE.md (skills) to ~/.claude/
               docker compose exec worker bin/claude-inbox-setup install-skills

  status       Show setup status
               docker compose exec worker bin/claude-inbox-setup status
EOF
    exit 1
}

# --- login ---
cmd_login() {
    # Ensure ~/.claude/ subdirs exist (named volume starts empty)
    mkdir -p "$HOME/.claude/debug" "$HOME/.claude/projects"
    # Ensure ~/.claude.json exists before claude tries to read it
    [ -f "$HOME/.claude.json" ] || echo '{}' > "$HOME/.claude.json"
    echo "Starting Claude Code login..."
    echo "(Auth will be saved to the claude_dot Docker volume)"
    claude login
}

# --- nlm-login ---
cmd_nlm_login() {
    local cdp_url="${CHROME_CDP_URL:-http://localhost:9222}"

    echo "Checking Chrome CDP at $cdp_url ..."
    if ! curl -sf "$cdp_url/json/version" >/dev/null 2>&1; then
        echo "ERROR: Cannot reach Chrome CDP at $cdp_url" >&2
        echo "Start Chrome: docker compose up -d chrome" >&2
        exit 1
    fi

    echo ""
    echo "Open browser at https://localhost:${KASM_PORT:-6901} to interact with Chrome."
    echo "VNC password: \${KASM_VNC_PW} (default: password)"
    echo ""

    echo "Running nlm login..."
    nlm login --provider openclaw --cdp-url "$cdp_url"
    echo "Done. Config saved to ~/.notebooklm-mcp-cli/"
}

# --- claude-mem ---
cmd_claude_mem() {
    local settings="$HOME/.claude/settings.json"
    mkdir -p "$(dirname "$settings")"

    # Create settings.json if it doesn't exist
    if [ ! -f "$settings" ]; then
        echo '{}' > "$settings"
    fi

    # Check if already configured
    if jq -e '.mcpServers["claude-mem"]' "$settings" >/dev/null 2>&1; then
        echo "claude-mem is already configured in $settings"
        return 0
    fi

    # Add claude-mem MCP server (stdio transport, connects to worker container via env vars)
    local tmp
    tmp=$(mktemp)
    jq '.mcpServers |= (. // {}) + {
        "claude-mem": {
            "command": "node",
            "args": ["/usr/local/lib/node_modules/claude-mem/plugin/scripts/mcp-server.cjs"]
        }
    }' "$settings" > "$tmp"
    mv "$tmp" "$settings"

    echo "Added claude-mem MCP server to $settings"
    echo "CLAUDE_MEM_WORKER_HOST and CLAUDE_MEM_WORKER_PORT are set via docker-compose environment."
    echo "Restart the worker to pick up the new config."
}

# --- status ---
cmd_status() {
    echo "=== claude-inbox setup status ==="

    # Claude auth (verify via CLI, not just file existence)
    local claude_auth
    if claude_auth=$(claude auth status 2>/dev/null) && \
       [ "$(echo "$claude_auth" | jq -r '.loggedIn')" = "true" ]; then
        local email method
        email=$(echo "$claude_auth" | jq -r '.email // "unknown"')
        method=$(echo "$claude_auth" | jq -r '.authMethod // "unknown"')
        echo "✓ Claude: authenticated ($method, $email)"
    else
        echo "✗ Claude: not authenticated      →  run: claude-inbox-setup login"
    fi

    # nlm auth
    if nlm login --check >/dev/null 2>&1; then
        echo "✓ NotebookLM: authenticated"
    else
        echo "✗ NotebookLM: not authenticated  →  run: claude-inbox-setup nlm-login"
    fi

    # claude-mem
    local settings="$HOME/.claude/settings.json"
    if [ -f "$settings" ] && jq -e '.mcpServers["claude-mem"]' "$settings" >/dev/null 2>&1; then
        echo "✓ claude-mem: configured"
    else
        echo "✗ claude-mem: not configured     →  run: claude-inbox-setup claude-mem"
    fi

    # Google Workspace CLI
    if command -v gws >/dev/null 2>&1; then
        local gws_auth
        gws_auth=$(gws auth status 2>/dev/null | jq -r '.auth_method // "none"')
        if [ "$gws_auth" != "none" ] && [ -n "$gws_auth" ]; then
            echo "✓ Google Workspace: authenticated ($gws_auth)"
        else
            echo "✗ Google Workspace: not configured →  run: claude-inbox-setup gws-login"
        fi
    fi

    # Playwright MCP
    if [ -f "$settings" ] && jq -e '.mcpServers["playwright"]' "$settings" >/dev/null 2>&1; then
        echo "✓ Playwright: configured"
    else
        echo "✗ Playwright: not configured   →  run: claude-inbox-setup playwright"
    fi

    # Skills (agent CLAUDE.md)
    if [ -f "$HOME/.claude/CLAUDE.md" ]; then
        echo "✓ Skills: installed (~/.claude/CLAUDE.md)"
    else
        echo "✗ Skills: not installed        →  run: claude-inbox-setup install-skills"
    fi

}

# --- gws-login ---
cmd_gws_login() {
    if ! command -v gws >/dev/null 2>&1; then
        echo "ERROR: gws CLI not found. Install: npm install -g @googleworkspace/cli" >&2
        exit 1
    fi

    # Check OAuth client credentials
    local client_id="${GOOGLE_WORKSPACE_CLI_CLIENT_ID:-}"
    local client_secret="${GOOGLE_WORKSPACE_CLI_CLIENT_SECRET:-}"
    if [ -z "$client_id" ] || [ -z "$client_secret" ]; then
        echo "ERROR: OAuth client credentials not set." >&2
        echo "" >&2
        echo "Set these in .env:" >&2
        echo "  GOOGLE_WORKSPACE_CLI_CLIENT_ID=xxx.apps.googleusercontent.com" >&2
        echo "  GOOGLE_WORKSPACE_CLI_CLIENT_SECRET=GOCSPX-xxx" >&2
        echo "" >&2
        echo "Create OAuth credentials at:" >&2
        echo "  https://console.cloud.google.com/apis/credentials" >&2
        echo "  (Desktop app type, enable Gmail/Calendar/Drive APIs)" >&2
        exit 1
    fi

    local cdp_url="${CHROME_CDP_URL:-http://localhost:9222}"
    local use_cdp=false

    # Check if Chrome CDP is available
    if curl -sf "$cdp_url/json/version" >/dev/null 2>&1; then
        use_cdp=true
    fi

    echo "Google Workspace CLI login"
    echo "=========================="

    if [ "$use_cdp" = true ]; then
        _gws_login_cdp "$cdp_url"
    else
        _gws_login_manual
    fi

    echo ""
    echo "Done. Credentials saved to ~/.config/gws/"
    echo "(Persisted in the gws_config Docker volume)"
}

# CDP-assisted login: open auth URL in Chrome, user completes login via VNC
# Chrome shares localhost with worker (sidecar), so OAuth callback reaches gws directly
_gws_login_cdp() {
    local cdp_url="$1"

    echo ""
    echo "Chrome detected at $cdp_url (sidecar, sharing localhost with worker)"
    echo "Complete Google login at https://localhost:${KASM_PORT:-6901}"
    echo "VNC password: \${KASM_VNC_PW} (default: password)"
    echo ""

    # Run gws in background, capture stdout+stderr to log file
    local gws_log
    gws_log=$(mktemp)
    gws auth login >"$gws_log" 2>&1 &
    local gws_pid=$!

    # Poll for auth URL (up to 15s)
    local auth_url="" attempts=0
    while [ -z "$auth_url" ] && [ $attempts -lt 30 ]; do
        auth_url=$(grep -oP 'https://accounts\.google\.com\S+' "$gws_log" 2>/dev/null | head -1 || true)
        [ -z "$auth_url" ] && { sleep 0.5; attempts=$((attempts + 1)); }
    done

    if [ -z "$auth_url" ]; then
        echo "ERROR: Could not extract auth URL from gws output." >&2
        echo "gws output:" >&2
        cat "$gws_log" >&2
        kill "$gws_pid" 2>/dev/null; wait "$gws_pid" 2>/dev/null || true
        rm -f "$gws_log"
        _gws_login_manual
        return
    fi

    echo "Auth URL detected. Opening in Chrome via CDP..."

    # URL-encode the auth URL so its query params (?response_type=code&...)
    # don't get parsed as CDP endpoint's own query parameters
    local encoded_url
    encoded_url=$(jq -rn --arg u "$auth_url" '$u | @uri')
    curl -sf -X PUT "$cdp_url/json/new?${encoded_url}" >/dev/null 2>&1 || true

    echo "Waiting for OAuth callback (Chrome and worker share localhost)..."
    echo "Complete login in VNC, callback will reach gws directly."

    # Wait for gws to finish (callback arrives via localhost)
    wait "$gws_pid" 2>/dev/null || true
    rm -f "$gws_log"
}

# Manual login fallback (no Chrome available)
_gws_login_manual() {
    echo ""
    echo "A browser URL will be displayed. Open it to authorize."
    echo "Select the API scopes you need (Gmail, Calendar, Drive, etc.)."
    echo ""
    echo "NOTE: If localhost callback is unreachable (Docker/SSH/remote):"
    echo "  1. Complete Google auth in your browser"
    echo "  2. Copy the redirect URL from the browser address bar (localhost:PORT/?code=...)"
    echo "  3. In another terminal: docker compose exec worker curl '<redirect-url>'"
    echo ""
    gws auth login
}

# --- playwright ---
cmd_playwright() {
    local settings="$HOME/.claude/settings.json"
    mkdir -p "$(dirname "$settings")"

    if [ ! -f "$settings" ]; then
        echo '{}' > "$settings"
    fi

    if jq -e '.mcpServers["playwright"]' "$settings" >/dev/null 2>&1; then
        echo "playwright is already configured in $settings"
        return 0
    fi

    local tmp
    tmp=$(mktemp)
    local cdp_endpoint="${CHROME_CDP_URL:-http://localhost:9222}"
    jq --arg cdp "$cdp_endpoint" '.mcpServers |= (. // {}) + {
        "playwright": {
            "command": "npx",
            "args": ["@playwright/mcp@latest", "--cdp-endpoint", $cdp]
        }
    }' "$settings" > "$tmp"
    mv "$tmp" "$settings"

    echo "Added Playwright MCP server to $settings"
    echo "Browser automation via remote Chrome (CDP: $cdp_endpoint)."
    echo "Restart the worker to pick up the new config."
}

# --- install-skills ---
cmd_install_skills() {
    local src="${1:-}"
    # Prefer workdir (live), fallback to /app (image layer)
    [ -z "$src" ] && src="${CLAUDE_INBOX_WORKDIR:-}/prompts/CLAUDE.md"
    [ -f "$src" ] || src="/app/prompts/CLAUDE.md"

    if [ ! -f "$src" ]; then
        echo "ERROR: No prompts/CLAUDE.md found" >&2
        exit 1
    fi

    mkdir -p "$HOME/.claude"
    cp "$src" "$HOME/.claude/CLAUDE.md"
    echo "Installed agent CLAUDE.md to $HOME/.claude/CLAUDE.md"
}

case "${1:-}" in
    login)          cmd_login ;;
    nlm-login)      cmd_nlm_login ;;
    gws-login)      cmd_gws_login ;;
    claude-mem)     cmd_claude_mem ;;
    playwright)     cmd_playwright ;;
    install-skills) cmd_install_skills "${2:-}" ;;
    status)         cmd_status ;;
    *)              usage ;;
esac
