#!/bin/bash
# worker: Claim task directories from tasks/ and execute them with claude
#
# Tasks are directories: tasks/{job_id}/ containing:
#   - prompt.txt (required): the prompt to send to Claude
#   - meta (optional): k=v metadata (session_id, channel, chat_id, etc.)
#   - attached files (optional): files Claude can read
#
# The preprocessor converts inbox items (new/) into task directories (tasks/).
# Results are saved to done/{job_id}/result.
# Context is retained by Claude's session storage.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Ensure ~/.claude/ subdirs and ~/.claude.json exist (named volume starts empty)
mkdir -p "$HOME/.claude/debug" "$HOME/.claude/projects"
[ -f "$HOME/.claude.json" ] || echo '{}' > "$HOME/.claude.json"

# Chrome requires perf_event_paranoid <= 2 to start; lower it only if needed
{ val=$(cat /proc/sys/kernel/perf_event_paranoid 2>/dev/null) && [ "$val" -gt 2 ] && echo 2 > /proc/sys/kernel/perf_event_paranoid; } 2>/dev/null || true

export CLAUDE_INBOX="${CLAUDE_INBOX:-$HOME/.claude-inbox}"
WORKER_ID="w.$$"
WORKDIR="${CLAUDE_INBOX_WORKDIR:-}"

# prompts/ and skills/ are always in /app (image layer)
SYSTEM="$ROOT_DIR/prompts/system.md"
SKILLS_DIR="$ROOT_DIR/skills"

# Install agent CLAUDE.md to ~/.claude/ (Claude Code auto-loads it every session)
if [ -f "$ROOT_DIR/prompts/CLAUDE.md" ]; then
    cp "$ROOT_DIR/prompts/CLAUDE.md" "$HOME/.claude/CLAUDE.md"
fi

mkdir -p "$CLAUDE_INBOX"/{tmp,new,tasks,done,failed,state} "$CLAUDE_INBOX/cur/$WORKER_ID"

source "$ROOT_DIR/lib/task.sh"
source "$ROOT_DIR/lib/observe.sh"
source "$ROOT_DIR/lib/notify.sh"
source "$ROOT_DIR/lib/util.sh"

log() { printf '[%s] [%s] %s\n' "$(date -Is)" "$WORKER_ID" "$*" >&2; }

cleanup() {
    session_unlock
    task_recover "$WORKER_ID"
    log "stopped"
}
trap cleanup EXIT INT TERM

system_prompt=""
[ -f "$SYSTEM" ] && system_prompt=$(cat "$SYSTEM")
# Append agent CLAUDE.md (skills, notification rules) to system prompt
agent_md="$ROOT_DIR/prompts/CLAUDE.md"
[ -f "$agent_md" ] && system_prompt="${system_prompt}"$'\n\n'"$(cat "$agent_md")"

# --- Read metadata from task directory ---
read_meta() {
    local task_dir="$1" key="$2"
    [ -f "$task_dir/meta" ] || return 0
    grep -oP "^${key}=\K.*" "$task_dir/meta" 2>/dev/null || true
}

wait_for_task() { wait_for_events "$CLAUDE_INBOX/tasks"; }

# --- Run claude with --resume fallback ---
# $1: prompt, $2: session_id, $3: workdir, $4: model
run_claude() {
    local prompt="$1" session_id="$2" task_workdir="${3:-}" task_model="${4:-}"

    # Task-level workdir takes priority over global CLAUDE_INBOX_WORKDIR
    local effective_workdir="${task_workdir:-${WORKDIR:-}}"
    if [ -n "$effective_workdir" ] && [ ! -d "$effective_workdir" ]; then
        log "  workdir '$effective_workdir' not found, falling back to WORKDIR='${WORKDIR:-}'"
        effective_workdir="${WORKDIR:-}"
    fi

    # Common arguments
    local common_args=(-p "$prompt" --dangerously-skip-permissions)
    local effective_model="${task_model:-${CLAUDE_MODEL:-}}"
    [ -n "$effective_model" ] && common_args+=(--model "$effective_model")
    [ -n "$system_prompt" ] && common_args+=(--system-prompt "$system_prompt")
    [ -d "$SKILLS_DIR" ] && common_args+=(--add-dir "$SKILLS_DIR")
    [ "${CLAUDE_CHROME:-}" = "1" ] && common_args+=(--chrome)

    local run_cmd="claude"
    local result="" rc=0

    _run() {
        if [ -n "$effective_workdir" ]; then
            result=$(cd "$effective_workdir" && $run_cmd "$@" "${common_args[@]}" 2>&1) || return $?
        else
            result=$($run_cmd "$@" "${common_args[@]}" 2>&1) || return $?
        fi
    }

    if [ -n "$session_id" ]; then
        # Try --resume first (existing session)
        log "  trying --resume session=$session_id"
        if _run --resume "$session_id"; then
            echo "$result"; return 0
        fi

        # --resume failed -> fall back to --session-id (new session)
        log "  --resume failed, falling back to --session-id"
        _run --session-id "$session_id" || rc=$?
    else
        # No session_id
        log "  no session_id, running without session"
        _run || rc=$?
    fi

    echo "$result"
    return $rc
}

# --- Main loop ---
log "started (inbox=$CLAUDE_INBOX)"
process_pending=true

while true; do
    [ "$process_pending" = false ] && wait_for_task
    process_pending=false

    task_dir=$(task_claim "$WORKER_ID") || continue
    process_pending=true

    job_id=$(basename "$task_dir")
    log "START $job_id"
    t0=$(date +%s)

    # Read prompt
    prompt=$(cat "$task_dir/prompt.txt")

    # Read metadata
    session_id=$(read_meta "$task_dir" "session_id")
    task_model=$(read_meta "$task_dir" "model")
    task_workdir=$(read_meta "$task_dir" "workdir")
    channel=$(read_meta "$task_dir" "channel")
    chat_id=$(read_meta "$task_dir" "chat_id")
    msg_id=$(read_meta "$task_dir" "msg_id")

    # Reconstruct metadata header for the agent (it needs chat_id, channel, etc.)
    if [ -f "$task_dir/meta" ] && [ -s "$task_dir/meta" ]; then
        meta_header="[$(tr '\n' ' ' < "$task_dir/meta" | sed 's/ $//')]"
        prompt="${meta_header}"$'\n\n'"${prompt}"
    fi

    # Append attached file hints to prompt
    attached_files=$(find "$task_dir" -maxdepth 1 -type f \
        ! -name prompt.txt ! -name meta ! -name result ! -name '.*' 2>/dev/null || true)
    if [ -n "$attached_files" ]; then
        prompt+=$'\n\n[Attached files — read with the Read tool]\n'
        while IFS= read -r f; do
            mime=$(file -b --mime-type "$f" 2>/dev/null || echo "unknown")
            prompt+="- $f ($mime)"$'\n'
        done <<< "$attached_files"
    fi

    # --- Session lock (prevent concurrent access to same Claude session) ---
    if ! session_lock "$session_id"; then
        log "QUEUE $job_id (session=$session_id busy, re-queuing)"
        mv "$task_dir" "$CLAUDE_INBOX/tasks/$job_id"
        sleep 2  # backoff to avoid tight claim-requeue loop
        continue
    fi

    # --- Progress notification (deterministic, pre-agent) ---
    if [ "$channel" = "telegram" ] && [ -n "$chat_id" ]; then
        notify_telegram "$chat_id" "..." "$msg_id"
    fi

    # --- Execute ---
    rc=0
    result=$(run_claude "$prompt" "$session_id" "$task_workdir" "$task_model") || rc=$?

    session_unlock
    dt=$(( $(date +%s) - t0 ))

    if [ $rc -eq 0 ]; then
        task_complete "$task_dir" "$result"
        log "DONE  $job_id (${dt}s, session=${session_id:-none}, model=${task_model:-${CLAUDE_MODEL:-default}})"
    else
        task_fail "$task_dir" "$result"
        log "FAIL  $job_id (exit=$rc, ${dt}s)"
        observe "task $job_id failed (exit=$rc, ${dt}s)"
    fi
done
