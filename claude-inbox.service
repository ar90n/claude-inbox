[Unit]
Description=claude-inbox task dispatcher
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/claude-inbox/bin/claude-inbox
Restart=always
RestartSec=10

# Environment
Environment=CLAUDE_INBOX=%h/.claude-inbox
Environment=WORKERS=1
# Environment=CLAUDE_INBOX_WORKDIR=/path/to/workdir
# Environment=OBSERVE_TELEGRAM_BOT_TOKEN=your-bot-token
# Environment=OBSERVE_TELEGRAM_CHAT_ID=your-chat-id
# Environment=TELEGRAM_BOT_TOKEN=your-bot-token
# Environment=TELEGRAM_CHAT_ID=your-chat-id

# Security
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=%h/.claude-inbox %h/.claude %t

[Install]
WantedBy=default.target
